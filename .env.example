# Supabase (required for auth, database, storage)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: Custom API URL for Edge Functions (payments, checkout, etc.)
# Set to your Supabase project URL + /functions/v1 for payments to work
# VITE_API_URL=https://your-project.supabase.co/functions/v1

# Stripe (for Edge Functions - set via supabase secrets)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
